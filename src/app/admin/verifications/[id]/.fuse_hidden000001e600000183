import Link from "next/link";
import { notFound, redirect } from "next/navigation";
import { Role } from "@prisma/client";
import { getCurrentUser } from "@/lib/auth";
import { prisma } from "@/lib/prisma";
import DecisionForm from "./DecisionForm";

export const dynamic = "force-dynamic";

export default async function AdminVerificationDetailPage({
  params,
}: {
  params: { id: string };
}) {
  const current = await getCurrentUser();
  if (!current) redirect("/login");
  if (current.role !== Role.ADMIN) {
    return (
      <div className="mx-auto max-w-md text-center">
        <h1 className="text-2xl font-bold">Admins only</h1>
      </div>
    );
  }

  const profile = await prisma.taskerProfile.findUnique({
    where: { userId: params.id },
    include: {
      user: { select: { id: true, name: true, email: true, createdAt: true } },
    },
  });
  if (!profile) notFound();

  return (
    <article className="mx-auto max-w-3xl space-y-6">
      <div>
        <Link
          href="/admin/verifications"
          className="text-sm text-brand-700 hover:underline"
        >
          ← Back to verifications
        </Link>
      </div>

      <header className="card flex items-start gap-4 p-6">
        {profile.photoUrl ? (
          <img
            src={profile.photoUrl}
            alt=""
            className="h-16 w-16 rounded-full object-cover"
          />
        ) : (
          <div className="h-16 w-16 rounded-full bg-gray-100" />
        )}
        <div className="min-w-0 flex-1">
          <h1 className="truncate text-xl font-bold">{profile.user.name}</h1>
          <p className="truncate text-sm text-gray-500">
            {profile.user.email}
          </p>
          <p className="mt-1 text-xs text-gray-500">
            Status: <strong>{profile.verificationStatus}</strong>
            {profile.verificationSubmittedAt ? (
              <>
                {" · "}submitted{" "}
                {new Date(profile.verificationSubmittedAt).toLocaleString()}
              </>
            ) : null}
          </p>
        </div>
      </header>

      <section className="card p-6">
        <h2 className="text-base font-semibold">Profile details</h2>
        <dl className="mt-3 grid grid-cols-[120px_1fr] gap-x-4 gap-y-2 text-sm">
          <dt className="text-gray-500">Rate</dt>
          <dd>${profile.hourlyRate}/hr</dd>
          <dt className="text-gray-500">Location</dt>
          <dd>{profile.location ?? "—"}</dd>
          <dt className="text-gray-500">Skills</dt>
          <dd>
            {profile.skills.length > 0 ? (
              <ul className="flex flex-wrap gap-1">
                {profile.skills.map((s) => (
                  <li
                    key={s}
                    className="inline-flex rounded-full bg-brand-50 px-2 py-0.5 text-xs text-brand-700"
                  >
                    {s}
                  </li>
                ))}
              </ul>
            ) : (
              "—"
            )}
          </dd>
          <dt className="text-gray-500">Bio</dt>
          <dd className="whitespace-pre-line">{profile.bio ?? "—"}</dd>
        </dl>
      </section>

      <section className="card p-6">
        <h2 className="text-base font-semibold">Identity documents</h2>
        <div className="mt-4 grid gap-4 sm:grid-cols-3">
          <DocBlock title="ID front" url={profile.idFrontUrl} />
          <DocBlock title="ID back" url={profile.idBackUrl} optional />
          <DocBlock title="Selfie with ID" url={profile.selfieUrl} />
        </div>
      </section>

      {profile.verificationStatus === "PENDING" ? (
        <section className="card p-6">
          <h2 className="text-base font-semibold">Decision</h2>
          <DecisionForm userId={profile.userId} />
        </section>
      ) : profile.verificationNote ? (
        <section className="card p-6">
          <h2 className="text-base font-semibold">Reviewer note</h2>
          <p className="mt-2 text-sm text-gray-700">{profile.verificationNote}</p>
        </section>
      ) : null}
    </article>
  );
}

function DocBlock({
  title,
  url,
  optional,
}: {
  title: string;
  url: string | null;
  optional?: boolean;
}) {
  return (
    <div>
      <p className="text-xs font-medium text-gray-600">{title}</p>
      {url ? (
        <a href={url} target="_blank" rel="noopener noreferrer">
          <img
            src={url}
            alt={title}
            className="mt-2 h-40 w-full rounded-md object-cover ring-1 ring-gray-200"
          />
        </a>
      ) : (
        <div className="mt-2 flex h-40 items-center justify-center rounded-md bg-gray-50 text-xs text-gray-500 ring-1 ring-gray-200">
          {optional ? "Not provided (optional)" : "Missing"}
        </div>
      )}
    </div>
  );
}
