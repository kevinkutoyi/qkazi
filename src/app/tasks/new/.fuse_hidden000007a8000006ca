"use client";

import { useRouter } from "next/navigation";
import { useState } from "react";
import TaskImagesUploader from "@/components/TaskImagesUploader";
import PlacesAutocomplete, {
  PlaceSelection,
} from "@/components/PlacesAutocomplete";
import DateTimePicker from "@/components/DateTimePicker";

type Category = { id: string; slug: string; name: string; emoji: string };

const BUDGET_CHIPS = [25, 50, 100, 200];

export default function NewTaskForm({
  categories,
  timezone,
}: {
  categories: Category[];
  timezone: string;
}) {
  const router = useRouter();
  const [title, setTitle] = useState("");
  const [description, setDescription] = useState("");
  const [categoryId, setCategoryId] = useState(categories[0]?.id ?? "");
  const [location, setLocation] = useState("");
  const [coords, setCoords] = useState<{ lat: number; lng: number } | null>(
    null,
  );
  const [scheduledFor, setScheduledFor] = useState<Date | null>(null);
  const [flexible, setFlexible] = useState(true);
  const [budget, setBudget] = useState<string>("");
  const [imageUrls, setImageUrls] = useState<string[]>([]);
  const [error, setError] = useState<string | null>(null);
  const [loading, setLoading] = useState(false);

  function handlePlace(p: PlaceSelection | null) {
    if (p) {
      setLocation(p.formatted);
      setCoords({ lat: p.latitude, lng: p.longitude });
    } else {
      setCoords(null);
    }
  }

  function setFlexibleOn() {
    setFlexible(true);
    setScheduledFor(null);
  }

  async function onSubmit(e: React.FormEvent) {
    e.preventDefault();
    setError(null);

    if (!flexible && !scheduledFor) {
      setError("Pick a date and time or choose 'I'm flexible'.");
      return;
    }

    const budgetNum = Number(budget);
    if (!Number.isFinite(budgetNum) || budgetNum <= 0) {
      setError("Set a budget greater than KSh 0.");
      return;
    }
    if (!location.trim()) {
      setError("Pick a location from the suggestions.");
      return;
    }

    setLoading(true);
    try {
      const res = await fetch("/api/tasks", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          title,
          description,
          categoryId,
          location,
          latitude: coords?.lat,
          longitude: coords?.lng,
          budget: budgetNum,
          scheduledFor: flexible ? null : scheduledFor?.toISOString(),
          imageUrls,
        }),
      });
      const data = await res.json();
      if (!res.ok) {
        setError(data.error ?? "Could not create task");
        return;
      }
      router.push(`/tasks/${data.task.id}`);
      router.refresh();
    } catch {
      setError("Network error");
    } finally {
      setLoading(false);
    }
  }

  return (
    <div className="mx-auto max-w-2xl">
      <header className="mb-6">
        <h1 className="text-2xl font-bold">Post a new task</h1>
        <p className="mt-1 text-sm text-gray-600">
          Describe what you need done. Taskers will send offers — you pick the
          best fit.
        </p>
      </header>

      <form onSubmit={onSubmit} className="space-y-6">
        <section className="card p-6">
          <h2 className="text-base font-semibold">What needs to be done?</h2>
          <div className="mt-4 space-y-4">
            <div>
              <label className="label" htmlFor="title">
                Title
              </label>
              <input
                id="title"
                required
                minLength={3}
                maxLength={120}
                className="input"
                value={title}
                onChange={(e) => setTitle(e.target.value)}
                placeholder="e.g. Move a 2-bedroom apartment"
              />
            </div>
            <div>
              <label className="label" htmlFor="description">
                Description
              </label>
              <textarea
                id="description"
                required
                minLength={10}
                maxLength={2000}
                className="input min-h-[140px]"
                value={description}
                onChange={(e) => setDescription(e.target.value)}
                placeholder="What needs doing? Any access notes, parking, special tools?"
              />
              <p className="mt-1 text-xs text-gray-400">
                {description.length}/2000
              </p>
            </div>
            <div>
              <label className="label" htmlFor="category">
                Category
              </label>
              <select
                id="category"
                required
                className="input"
                value={categoryId}
                onChange={(e) => setCategoryId(e.target.value)}
              >
                {categories.map((c) => (
                  <option key={c.id} value={c.id}>
                    {c.emoji} {c.name}
                  </option>
                ))}
              </select>
            </div>
          </div>
        </section>

        <section className="card p-6">
          <h2 className="text-base font-semibold">Photos (optional)</h2>
          <p className="mt-1 text-xs text-gray-500">
            Photos help taskers understand the job and quote accurately.
          </p>
          <div className="mt-4">
            <TaskImagesUploader onChange={setImageUrls} />
          </div>
        </section>

        <section className="card p-6">
          <h2 className="text-base font-semibold">Where & when</h2>
          <div className="mt-4 space-y-4">
            <div>
              <label className="label" htmlFor="location">
                Location
              </label>
              <PlacesAutocomplete
                id="location"
                required
                placeholder="e.g. Westlands, Nairobi"
                onSelect={handlePlace}
              />
              <p className="mt-1 text-xs text-gray-500">
                {coords
                  ? "Location pinned."
                  : "Pick a result so taskers can find you on the map."}
              </p>
            </div>

            <div>
              <span className="label">When?</span>
              <div className="grid grid-cols-2 gap-2">
                <button
                  type="button"
                  onClick={setFlexibleOn}
                  className={`rounded-md border px-3 py-2 text-sm font-medium transition ${
                    flexible
                      ? "border-brand-600 bg-brand-50 text-brand-700"
                      : "border-gray-300 bg-white text-gray-700 hover:bg-gray-50"
                  }`}
                >
                  I&apos;m flexible
                </button>
                <button
                  type="button"
                  onClick={() => setFlexible(false)}
                  className={`rounded-md border px-3 py-2 text-sm font-medium transition ${
                    !flexible
                      ? "border-brand-600 bg-brand-50 text-brand-700"
                      : "border-gray-300 bg-white text-gray-700 hover:bg-gray-50"
                  }`}
                >
                  Pick a date
                </button>
              </div>

              {!flexible ? (
                <div className="mt-3">
                  <DateTimePicker
                    value={scheduledFor}
                    onChange={setScheduledFor}
                    timezone={timezone}
                    mode="datetime"
                    required
                  />
                </div>
              ) : null}
            </div>
          </div>
        </section>

        <section className="card p-6">
          <h2 className="text-base font-semibold">Your budget</h2>
          <div className="mt-3 flex flex-wrap gap-2">
            {BUDGET_CHIPS.map((amt) => (
              <button
                key={amt}
                type="button"
                onClick={() => setBudget(String(amt))}
                className={`rounded-full border px-3 py-1.5 text-sm font-medium transition ${
                  budget === String(amt)
                    ? "border-brand-600 bg-brand-50 text-brand-700"
                    : "border-gray-300 bg-white text-gray-700 hover:bg-gray-50"
                }`}
              >
                KSh {amt}
              </button>
            ))}
          </div>
          <div className="mt-3">
            <label className="label" htmlFor="budget">
              Or enter an amount (KSh)
            </label>
            <div className="relative">
              <span className="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3 text-sm text-gray-500">
                KSh              </span>
              <input
                id="budget"
                type="number"
                min={1}
                required
                className="input pl-7"
                value={budget}
                onChange={(e) => setBudget(e.target.value)}
                placeholder="0"
              />
            </div>
          </div>
        </section>

        {error ? <p className="text-sm text-red-600">{error}</p> : null}

        <div className="flex flex-col-reverse gap-3 sm:flex-row sm:justify-end">
          <button
            type="button"
            className="btn-secondary"
            onClick={() => router.back()}
          >
            Cancel
          </button>
          <button type="submit" className="btn-primary" disabled={loading}>
            {loading ? "Posting…" : "Post task"}
          </button>
        </div>
      </form>
    </div>
  );
}
