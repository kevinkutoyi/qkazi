import Link from "next/link";
import { Prisma, Role, VerificationStatus } from "@prisma/client";
import { prisma } from "@/lib/prisma";
import { bboxAround, haversineKm, isValidLatLng } from "@/lib/geo";
import DistanceFilter from "../tasks/DistanceFilter";

export const dynamic = "force-dynamic";

export default async function TaskersPage({
  searchParams,
}: {
  searchParams: {
    skill?: string;
    location?: string;
    maxRate?: string;
    lat?: string;
    lng?: string;
    radiusKm?: string;
    sort?: string;
  };
}) {
  // Parse geo params upfront — they shape both the where clause (bbox) and
  // the post-fetch refine + sort step.
  const lat = searchParams.lat ? Number(searchParams.lat) : NaN;
  const lng = searchParams.lng ? Number(searchParams.lng) : NaN;
  const radiusKm = searchParams.radiusKm ? Number(searchParams.radiusKm) : NaN;
  const hasCoords = isValidLatLng(lat, lng);
  const usingDistance =
    hasCoords && Number.isFinite(radiusKm) && radiusKm > 0;

  const profileFilters: Prisma.TaskerProfileWhereInput = {
    onboardingCompletedAt: { not: null },
    verificationStatus: {
      in: [VerificationStatus.APPROVED, VerificationStatus.PENDING],
    },
  };
  if (searchParams.skill) profileFilters.skills = { has: searchParams.skill };
  if (searchParams.location)
    profileFilters.location = {
      contains: searchParams.location,
      mode: "insensitive",
    };
  if (searchParams.maxRate) {
    const rate = Number(searchParams.maxRate);
    if (!Number.isNaN(rate)) profileFilters.hourlyRate = { lte: rate };
  }
  if (usingDistance) {
    const box = bboxAround(lat, lng, radiusKm);
    profileFilters.latitude = { gte: box.minLat, lte: box.maxLat };
    profileFilters.longitude = { gte: box.minLng, lte: box.maxLng };
  }

  const rows = await prisma.user.findMany({
    where: {
      role: Role.TASKER,
      taskerProfile: { is: profileFilters },
    },
    select: {
      id: true,
      name: true,
      taskerProfile: {
        select: {
          bio: true,
          hourlyRate: true,
          location: true,
          latitude: true,
          longitude: true,
          skills: true,
          photoUrl: true,
          verificationStatus: true,
          ratingAvg: true,
          ratingCount: true,
        },
      },
    },
    orderBy: { createdAt: "desc" },
  });

  // Refine to exact radius + decorate with distance + sort.
  const taskers = rows.map((t) => {
    const p = t.taskerProfile;
    const distanceKm =
      usingDistance && p?.latitude != null && p?.longitude != null
        ? haversineKm(lat, lng, p.latitude, p.longitude)
        : null;
    return { ...t, distanceKm };
  });
  const visible = usingDistance
    ? taskers
        .filter((t) => t.distanceKm != null && t.distanceKm <= radiusKm)
        .sort(
          (a, b) =>
            (a.distanceKm ?? Number.POSITIVE_INFINITY) -
            (b.distanceKm ?? Number.POSITIVE_INFINITY),
        )
    : taskers;

  return (
    <div className="space-y-6">
      <div>
        <h1 className="text-2xl font-bold">Find a tasker</h1>
        <p className="text-sm text-gray-600">
          Browse skilled people ready to help. Only verified or in-review
          profiles are shown.
        </p>
      </div>

      <form className="card grid gap-3 p-4 sm:grid-cols-[1fr_180px_140px_auto] sm:items-end">
        <div>
          <label className="label" htmlFor="skill">
            Skill
          </label>
          <input
            id="skill"
            name="skill"
            defaultValue={searchParams.skill ?? ""}
            className="input"
            placeholder="e.g. Plumbing"
          />
        </div>
        <div>
          <label className="label" htmlFor="location">
            Location
          </label>
          <input
            id="location"
            name="location"
            defaultValue={searchParams.location ?? ""}
            className="input"
            placeholder="city or neighborhood"
          />
        </div>
        <div>
          <label className="label" htmlFor="maxRate">
            Max rate
          </label>
          <input
            id="maxRate"
            name="maxRate"
            type="number"
            min={1}
            defaultValue={searchParams.maxRate ?? ""}
            className="input"
          />
        </div>
        <button type="submit" className="btn-primary self-end">
          Filter
        </button>

        <div className="sm:col-span-4">
          <DistanceFilter
            initialLat={hasCoords ? lat : undefined}
            initialLng={hasCoords ? lng : undefined}
            initialRadius={
              Number.isFinite(radiusKm) && radiusKm > 0 ? radiusKm : undefined
            }
          />
        </div>
      </form>

      {visible.length === 0 ? (
        <div className="card p-8 text-center text-gray-600">
          {usingDistance
            ? `No taskers within ${radiusKm} km of your location match these filters.`
            : "No taskers match your filters yet."}
        </div>
      ) : (
        <div className="grid gap-4 sm:grid-cols-2">
          {visible.map((t) => {
            const isApproved =
              t.taskerProfile?.verificationStatus ===
              VerificationStatus.APPROVED;
            return (
              <Link
                key={t.id}
                href={`/taskers/${t.id}`}
                className="card block p-5 transition hover:shadow-md"
              >
                <div className="flex items-start gap-3">
                  {t.taskerProfile?.photoUrl ? (
                    <img
                      src={t.taskerProfile.photoUrl}
                      alt=""
                      className="h-12 w-12 shrink-0 rounded-full object-cover"
                    />
                  ) : (
                    <div className="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-brand-100 text-sm font-semibold text-brand-700">
                      {t.name
                        .split(/\s+/)
                        .slice(0, 2)
                        .map((p) => p[0]?.toUpperCase() ?? "")
                        .join("")}
                    </div>
                  )}
                  <div className="min-w-0 flex-1">
                    <div className="flex items-start justify-between gap-3">
                      <div className="min-w-0">
                        <div className="flex flex-wrap items-center gap-1.5">
                          <h3 className="truncate text-base font-semibold">
                            {t.name}
                          </h3>
                          {isApproved ? (
                            <span
                              className="badge bg-brand-100 text-brand-700"
                              title="Identity verified"
                            >
                              ✓ Verified
                            </span>
                          ) : null}
                        </div>
                        <p className="mt-0.5 truncate text-xs text-gray-500">
                          {t.taskerProfile?.location ?? "—"}
                          {t.distanceKm != null ? (
                            <>
                              {" · "}
                              <span className="text-brand-700">
                                {t.distanceKm < 1
                                  ? `${Math.round(t.distanceKm * 1000)} m away`
                                  : `${t.distanceKm.toFixed(1)} km away`}
                              </span>
                            </>
                          ) : null}
                          {t.taskerProfile?.ratingCount &&
                          t.taskerProfile.ratingCount > 0 ? (
                            <>
                              {" · "}
                              ★ {t.taskerProfile.ratingAvg.toFixed(1)} (
                              {t.taskerProfile.ratingCount})
                            </>
                          ) : null}
                        </p>
                      </div>
                      {t.taskerProfile ? (
                        <span className="shrink-0 text-sm font-medium text-gray-700">
                          ${t.taskerProfile.hourlyRate}/hr
                        </span>
                      ) : null}
                    </div>
                    {t.taskerProfile?.bio ? (
                      <p className="mt-2 line-clamp-2 text-sm text-gray-700">
                        {t.taskerProfile.bio}
                      </p>
                    ) : null}
                    {t.taskerProfile?.skills?.length ? (
                      <div className="mt-3 flex flex-wrap gap-1">
                        {t.taskerProfile.skills.slice(0, 5).map((s) => (
                          <span
                            key={s}
                            className="badge bg-brand-50 text-brand-700"
                          >
                            {s}
                          </span>
                        ))}
                      </div>
                    ) : null}
                  </div>
                </div>
              </Link>
            );
          })}
        </div>
      )}
    </div>
  );
}
