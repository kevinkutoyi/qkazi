import Link from "next/link";
import { notFound } from "next/navigation";
import { BookingStatus, Role, TaskStatus } from "@prisma/client";
import { prisma } from "@/lib/prisma";
import { getCurrentUser } from "@/lib/auth";
import { formatScheduled, zoneLabel } from "@/lib/datetime";
import MapPreview from "@/components/MapPreview";
import TaskActions from "./TaskActions";
import LiveOffersListener from "./LiveOffersListener";
import ReviewForm from "./ReviewForm";

export const dynamic = "force-dynamic";

export default async function TaskDetailPage({
  params,
}: {
  params: { id: string };
}) {
  const [task, user] = await Promise.all([
    prisma.task.findUnique({
      where: { id: params.id },
      include: {
        customer: { select: { id: true, name: true } },
        category: {
          select: { id: true, slug: true, name: true, emoji: true },
        },
        images: {
          orderBy: { sortOrder: "asc" },
          select: { id: true, url: true },
        },
        bookings: {
          include: {
            tasker: {
              select: {
                id: true,
                name: true,
                taskerProfile: {
                  select: {
                    hourlyRate: true,
                    location: true,
                    skills: true,
                    photoUrl: true,
                    ratingAvg: true,
                    ratingCount: true,
                  },
                },
              },
            },
            reviews: {
              select: {
                id: true,
                authorId: true,
                rating: true,
                comment: true,
                createdAt: true,
              },
            },
          },
          orderBy: [{ priceCents: "asc" }, { createdAt: "desc" }],
        },
      },
    }),
    getCurrentUser(),
  ]);

  if (!task) notFound();

  // Fetch the viewer's stored timezone for date display.
  let viewerTz: string | null = null;
  if (user) {
    const u = await prisma.user.findUnique({
      where: { id: user.sub },
      select: { timezone: true },
    });
    viewerTz = u?.timezone ?? null;
  }
  const tz = viewerTz ?? "UTC";

  const isOwner = user?.sub === task.customerId;
  const isTasker = user?.role === Role.TASKER;
  const hasOffered =
    isTasker && task.bookings.some((b) => b.taskerId === user!.sub);
  const schedule = task.scheduledFor
    ? formatScheduled(task.scheduledFor, tz)
    : null;
  const budgetDollars = task.budget;

  return (
    <article className="grid gap-8 lg:grid-cols-3">
      <div className="space-y-4 lg:col-span-2">
        <div>
          <Link href="/tasks" className="text-sm text-brand-700 hover:underline">
            ← Back to tasks
          </Link>
        </div>
        <div className="card p-6">
          <div className="flex items-start justify-between gap-3">
            <h1 className="text-2xl font-bold">{task.title}</h1>
            <span className="badge bg-brand-100 text-brand-700">
              {task.status}
            </span>
          </div>
          <p className="mt-2 text-sm text-gray-500">
            Posted by {task.customer.name} ·{" "}
            {new Date(task.createdAt).toLocaleDateString()}
          </p>

          <div className="mt-4 grid grid-cols-2 gap-4 text-sm sm:grid-cols-4">
            <div>
              <div className="text-gray-500">Category</div>
              <div className="font-medium">
                {task.category ? (
                  <>
                    <span className="mr-1" aria-hidden="true">
                      {task.category.emoji}
                    </span>
                    {task.category.name}
                  </>
                ) : (
                  "—"
                )}
              </div>
            </div>
            <div>
              <div className="text-gray-500">Location</div>
              <div className="font-medium">{task.location}</div>
            </div>
            <div>
              <div className="text-gray-500">Budget</div>
              <div className="font-medium">${task.budget}</div>
            </div>
            <div>
              <div className="text-gray-500">When</div>
              <div className="font-medium">
                {schedule ?? (
                  <span className="text-gray-500">Flexible</span>
                )}
              </div>
              {schedule ? (
                <div className="text-[11px] text-gray-400">
                  {zoneLabel(tz)}
                </div>
              ) : null}
            </div>
          </div>

          {task.latitude != null && task.longitude != null ? (
            <section className="mt-6">
              <h2 className="text-sm font-semibold text-gray-900">Location</h2>
              <div className="mt-3">
                <MapPreview
                  lat={task.latitude}
                  lng={task.longitude}
                  label={task.location}
                  height={200}
                />
                <p className="mt-2 text-xs text-gray-500">
                  Approximate area shown. Exact address is shared after an
                  offer is accepted.
                </p>
              </div>
            </section>
          ) : null}

          {task.images.length > 0 ? (
            <section className="mt-6">
              <h2 className="text-sm font-semibold text-gray-900">Photos</h2>
              <ul className="mt-3 grid grid-cols-3 gap-3 sm:grid-cols-4">
                {task.images.map((img) => (
                  <li key={img.id}>
                    <a
                      href={img.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      className="block aspect-square overflow-hidden rounded-md ring-1 ring-inset ring-gray-200 hover:ring-brand-400"
                    >
                      <img
                        src={img.url}
                        alt=""
                        className="h-full w-full object-cover"
                      />
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          ) : null}

          <div className="mt-6 whitespace-pre-line text-gray-800">
            {task.description}
          </div>
        </div>

        {isOwner ? (
          <section className="card p-6">
            <div className="flex items-center justify-between gap-3">
              <h2 className="text-lg font-semibold">
                Offers{" "}
                <span className="ml-1 text-sm font-normal text-gray-500">
                  ({task.bookings.length})
                </span>
              </h2>
              <LiveOffersListener taskId={task.id} />
            </div>

            {task.bookings.length === 0 ? (
              <p className="mt-3 text-sm text-gray-600">
                No offers yet. They&apos;ll appear here automatically as taskers
                send them in.
              </p>
            ) : (
              <ul className="mt-4 space-y-3">
                {task.bookings.map((b) => {
                  const offerDollars =
                    b.priceCents != null ? b.priceCents / 100 : null;
                  const diff =
                    offerDollars != null ? offerDollars - budgetDollars : null;
                  const proposedTime = b.scheduledAt
                    ? formatScheduled(b.scheduledAt, tz)
                    : null;
                  return (
                    <li
                      key={b.id}
                      className="rounded-md border border-gray-200 p-4"
                    >
                      <div className="flex items-start justify-between gap-3">
                        <div className="flex items-start gap-3">
                          {b.tasker.taskerProfile?.photoUrl ? (
                            <img
                              src={b.tasker.taskerProfile.photoUrl}
                              alt=""
                              className="h-10 w-10 rounded-full object-cover"
                            />
                          ) : (
                            <div className="h-10 w-10 rounded-full bg-brand-100" />
                          )}
                          <div className="min-w-0">
                            <Link
                              href={`/taskers/${b.tasker.id}`}
                              className="font-medium hover:underline"
                            >
                              {b.tasker.name}
                            </Link>
                            <div className="text-xs text-gray-500">
                              {b.tasker.taskerProfile?.location}
                              {b.tasker.taskerProfile?.hourlyRate
                                ? ` · usually $${b.tasker.taskerProfile.hourlyRate}/hr`
                                : ""}
                              {b.tasker.taskerProfile?.ratingCount &&
                              b.tasker.taskerProfile.ratingCount > 0 ? (
                                <>
                                  {" · "}
                                  ★{" "}
                                  {b.tasker.taskerProfile.ratingAvg.toFixed(1)}{" "}
                                  ({b.tasker.taskerProfile.ratingCount})
                                </>
                              ) : null}
                            </div>
                            {b.message ? (
                              <p className="mt-2 text-sm text-gray-700">
                                “{b.message}”
                              </p>
                            ) : null}
                            {proposedTime ? (
                              <p className="mt-2 text-xs text-brand-700">
                                Proposes 📅 {proposedTime}
                              </p>
                            ) : null}
                          </div>
                        </div>

                        <div className="text-right">
                          {offerDollars != null ? (
                            <p className="text-lg font-semibold text-gray-900">
                              ${offerDollars.toFixed(0)}
                            </p>
                          ) : null}
                          {diff != null && diff !== 0 ? (
                            <p
                              className={`text-[11px] font-medium ${
                                diff > 0
                                  ? "text-yellow-700"
                                  : "text-brand-700"
                              }`}
                            >
                              {diff > 0
                                ? `+$${diff.toFixed(0)} over budget`
                                : `−$${Math.abs(diff).toFixed(0)} under budget`}
                            </p>
                          ) : diff === 0 ? (
                            <p className="text-[11px] text-gray-500">
                              at budget
                            </p>
                          ) : null}
                          <span className="badge mt-1 bg-gray-100 text-gray-700">
                            {b.status}
                          </span>
                        </div>
                      </div>

                      {task.status === TaskStatus.OPEN &&
                      b.status === BookingStatus.PENDING ? (
                        <TaskActions bookingId={b.id} kind="customer-decide" />
                      ) : null}
                      {b.status === BookingStatus.ACCEPTED &&
                      task.status === TaskStatus.ASSIGNED ? (
                        <TaskActions
                          bookingId={b.id}
                          kind="customer-complete"
                        />
                      ) : null}
                      {b.status === BookingStatus.COMPLETED ? (
                        <CompletedBookingReview
                          bookingId={b.id}
                          taskerName={b.tasker.name}
                          myAuthorId={user?.sub ?? null}
                          reviews={b.reviews}
                        />
                      ) : null}
                    </li>
                  );
                })}
              </ul>
            )}
          </section>
        ) : null}
      </div>

      <aside className="space-y-4">
        <div className="card p-6">
          {!user ? (
            <>
              <p className="text-sm text-gray-700">
                Log in as a tasker to send an offer.
              </p>
              <Link
                href="/login"
                className="btn-primary mt-3 inline-flex w-full"
              >
                Log in
              </Link>
            </>
          ) : isOwner ? (
            <p className="text-sm text-gray-600">This is your task.</p>
          ) : isTasker && task.status === TaskStatus.OPEN ? (
            hasOffered ? (
              <p className="text-sm text-gray-700">
                You&apos;ve already sent an offer. Watch your dashboard for a
                response.
              </p>
            ) : (
              <TaskActions
                taskId={task.id}
                taskBudget={task.budget}
                timezone={tz}
                kind="tasker-offer"
              />
            )
          ) : (
            (() => {
              // Tasker viewing a task they completed — offer review of the
              // customer if not already given.
              if (!isTasker) {
                return (
                  <p className="text-sm text-gray-600">
                    This task is not accepting new offers.
                  </p>
                );
              }
              const myBooking = task.bookings.find(
                (b) =>
                  b.taskerId === user!.sub &&
                  b.status === BookingStatus.COMPLETED,
              );
              if (!myBooking) {
                return (
                  <p className="text-sm text-gray-600">
                    This task is not accepting new offers.
                  </p>
                );
              }
              const already = myBooking.reviews.some(
                (r) => r.authorId === user!.sub,
              );
              if (already) {
                return (
                  <p className="text-sm text-gray-600">
                    Thanks for reviewing this customer.
                  </p>
                );
              }
              return (
                <>
                  <p className="mb-3 text-sm text-gray-700">
                    Job complete — review the customer.
                  </p>
                  <ReviewForm
                    bookingId={myBooking.id}
                    subjectName={task.customer.name}
                  />
                </>
              );
            })()
          )}
        </div>
      </aside>
    </article>
  );
}

function CompletedBookingReview({
  bookingId,
  taskerName,
  myAuthorId,
  reviews,
}: {
  bookingId: string;
  taskerName: string;
  myAuthorId: string | null;
  reviews: { id: string; authorId: string; rating: number; comment: string | null; createdAt: Date }[];
}) {
  if (!myAuthorId) return null;
  const already = reviews.some((r) => r.authorId === myAuthorId);
  return (
    <div className="mt-4 rounded-md border border-gray-200 bg-gray-50/40 p-4">
      {already ? (
        <>
          <p className="text-xs font-semibold uppercase tracking-wide text-gray-500">
            Your review
          </p>
          {reviews
            .filter((r) => r.authorId === myAuthorId)
            .map((r) => (
              <div key={r.id} className="mt-2">
                <div className="flex items-center gap-1 text-yellow-500">
                  {Array.from({ length: 5 }).map((_, i) => (
                    <span key={i} aria-hidden="true">
                      {i < r.rating ? "★" : "☆"}
                    </span>
                  ))}
                </div>
                {r.comment ? (
                  <p className="mt-2 text-sm text-gray-700">“{r.comment}”</p>
                ) : null}
              </div>
            ))}
        </>
      ) : (
        <>
          <p className="text-xs font-semibold uppercase tracking-wide text-gray-500">
            Leave a review
          </p>
          <div className="mt-2">
            <ReviewForm bookingId={bookingId} subjectName={taskerName} />
          </div>
        </>
      )}
    </div>
  );
}
