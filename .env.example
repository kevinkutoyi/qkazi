# Copy this file to .env and fill in values for local development.

# Where the app is reachable. Used for email links and the Google OAuth redirect URI.
APP_URL="http://localhost:3000"

# Postgres connection string. Matches docker-compose.yml defaults.
DATABASE_URL="postgresql://qkazi:qkazi@localhost:5432/qkazi?schema=public"

# Used to sign JWT access tokens. Generate with: openssl rand -base64 32
JWT_SECRET="replace-me-with-a-long-random-string"

# JWT lifetime
JWT_EXPIRES_IN="7d"

# --- Email (Resend) ---
# Sign up at https://resend.com, create an API key.
RESEND_API_KEY=""
# The "from" address shown to users. For local dev you can use Resend's onboarding
# sender (onboarding@resend.dev) without verifying a domain.
RESEND_FROM="Qkazi <onboarding@resend.dev>"

# --- Google OAuth ---
# https://console.cloud.google.com → APIs & Services → Credentials → OAuth client ID (Web)
# Authorized redirect URI: ${APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Google Maps ---
# https://console.cloud.google.com → APIs & Services → Credentials → API key
# Enable: Maps JavaScript API, Places API, Maps Static API.
# Lock the key down with HTTP referrer restrictions (e.g. http://localhost:3000/*).
# This is intentionally a NEXT_PUBLIC_ env var — Maps JS runs in the browser.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# --- Pesapal payments ---
# Sign up at https://pesapal.com (sandbox is at https://developer.pesapal.com).
# `sandbox` uses cybqa.pesapal.com; switch to `production` for live keys.
PESAPAL_ENV="sandbox"
PESAPAL_CONSUMER_KEY=""
PESAPAL_CONSUMER_SECRET=""
# Optional. If left blank, the app auto-registers an IPN with Pesapal on first
# checkout and caches the id in the PesapalIpn table. Set this explicitly to
# pin a specific IPN id across deploys.
PESAPAL_IPN_ID=""

# Default display currency. Pesapal works with KES and USD (among others).
DEFAULT_CURRENCY="KES"

# --- File storage ---
# If S3_BUCKET is unset, uploads go to ./public/uploads/ (dev only — won't
# work on serverless or multi-instance deploys). Set S3_BUCKET (and friends)
# to use S3-compatible object storage: AWS S3, Cloudflare R2, MinIO,
# Backblaze B2, DigitalOcean Spaces, etc.
S3_BUCKET=""
S3_REGION="auto"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# Set for non-AWS endpoints. Examples:
#   Cloudflare R2: https://<account>.r2.cloudflarestorage.com
#   MinIO:         http://localhost:9000
#   DO Spaces:     https://<region>.digitaloceanspaces.com
S3_ENDPOINT=""
# "true" forces path-style addressing (needed by MinIO and some older services).
S3_FORCE_PATH_STYLE="false"
# Optional public base URL for objects under photos/ and tasks/ (e.g. a CDN
# in front of the bucket). When set, those URLs are returned directly; when
# blank, every read goes through the auth-gated /api/files proxy.
S3_PUBLIC_BASE_URL=""

# --- Realtime pub/sub (SSE: live offers + chat) ---
# If unset, the app uses an in-process event bus that works perfectly for
# `next dev` and any single-process deploy. For multi-instance deploys
# (e.g. multiple Vercel functions, multiple Kubernetes pods, a horizontally
# scaled Docker service) set REDIS_URL so SSE events fan out across nodes.
# Works with any Redis-compatible service: managed Redis, Upstash,
# Cloudflare/Vercel KV (Redis-compatible mode), AWS ElastiCache, etc.
#   redis://default:<password>@<host>:6379
#   rediss://...   (TLS)
REDIS_URL=""
